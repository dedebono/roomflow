# ============================================================
# RoomFlow — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# DATABASE
# ============================================================
POSTGRES_PASSWORD=change_me_in_production

# ============================================================
# AUTHENTICATION
# ============================================================
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# ============================================================
# WAHA (WhatsApp Business API Integration)
# ============================================================
# Enable/disable WhatsApp integration
WAHA_ENABLED=true

# WAHA API endpoint (e.g. http://<server-ip>:3000)
WAHA_API_URL=http://localhost:3000

# WAHA session name (default or custom)
WAHA_SESSION=default

# WAHA API key (from WAHA dashboard)
WAHA_API_KEY=your_waha_api_key_here

# ============================================================
# FRONTEND / PUBLIC URL
# ============================================================
# Used in Docker build to set NEXT_PUBLIC_API_URL
# For development: http://localhost
# For production: https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# Base URL without /api suffix (for image URLs & WebSocket fallback)
# Usually same as API_URL without /api
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Allowed CORS origins (comma-separated)
# For development: http://localhost:3001,http://localhost:3000
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ============================================================
# EMAIL (Optional — not yet fully implemented)
# ============================================================
EMAIL_ENABLED=false
EMAIL_FROM=noreply@roomflow.local
# SMTP settings (leave blank if EMAIL_ENABLED=false)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============================================================
# STORAGE
# ============================================================
# LOCAL is the default and recommended for single-server deployments
STORAGE_TYPE=LOCAL

# ============================================================
# NOTES FOR DEPLOYMENT
# ============================================================
# 1. Generate JWT_SECRET: openssl rand -base64 32
# 2. Set a strong POSTGRES_PASSWORD
# 3. Update WAHA credentials if using WhatsApp integration
# 4. Update NEXT_PUBLIC_API_URL to match your domain
# 5. Copy .env.example to .env before running docker compose